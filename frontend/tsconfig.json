  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    // Вот эта часть важна для путей:
    "baseUrl": ".",
    "paths": {
      "@backend/*": ["../backend/src/*"]
    }
